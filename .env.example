OPENROUTER_API_KEY= ...
OPENROUTER_BASE_URL= https://openrouter.ai/api/v1

LANGSMITH_API_KEY= ...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Mult-Agent-Sentinel
LANGCHAIN_SESSION=default

SENTINEL_MODEL=deepseek/deepseek-chat-v3.1:free
SENTINEL_MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free

MONGO_URI= mongodb://localhost:27017/sentinel

GRAFANA_URL= ...
GRAFANA_API_KEY= ...

# GitHub MCP (read-only). PAT classico com escopo `repo:read` (privado) ou `public_repo` (publico).
# Gere em https://github.com/settings/tokens — opcional, agente vira degradado sem ele.
GITHUB_PERSONAL_ACCESS_TOKEN=
# Liga o GitHub MCP no pipeline. Mantenha 0 se usar so o seed (commits fake travam o agente).
# Use 1 quando apontar pra um repo real com commits/PRs validos.
SENTINEL_USE_GITHUB= ...
# Repo onde o agente fara search_code (ex: tinobelmont/multi-agent-sentinel).
# So usado quando SENTINEL_USE_GITHUB=1. NUNCA chama get_commit (os SHAs do seed sao fake).
SENTINEL_GITHUB_REPO=

SENTINEL_MAX_ITERATIONS=5
SENTINEL_TOKEN_BUDGET=50000
SENTINEL_AGENT_TIMEOUT_S=30