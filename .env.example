# ============================================================================
# LLM (obrigatorio para sair do modo degradado)
# ============================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelos: ":free" do OpenRouter NAO funciona com tool-calling de MCPs grandes
# (filesystem + playwright = ~15 tools combinadas). Use modelos pagos.
SENTINEL_MODEL=anthropic/claude-sonnet-4.5
SENTINEL_MODEL_FAST=anthropic/claude-haiku-4.5
SENTINEL_MAX_TOKENS=4096

# ============================================================================
# LangSmith tracing (opcional — LangChain le essas vars automaticamente)
# ============================================================================
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Multi-Agent-Sentinel
LANGCHAIN_SESSION=default

# ============================================================================
# MongoDB (obrigatorio — sem ele a investigacao nao tem contexto)
# ============================================================================
MONGO_URI=mongodb://localhost:27017/sentinel

# ============================================================================
# Grafana MCP (opcional — sem ele, confianca capada em 70%)
# ============================================================================
GRAFANA_URL=
GRAFANA_API_KEY=

# ============================================================================
# GitHub MCP (opcional, read-only)
# PAT em https://github.com/settings/tokens com escopo public_repo ou repo
# Mantenha SENTINEL_USE_GITHUB=0 ao rodar com o seed (SHAs sao ficticios)
# ============================================================================
GITHUB_PERSONAL_ACCESS_TOKEN=
SENTINEL_USE_GITHUB=0
SENTINEL_GITHUB_REPO=

# ============================================================================
# Limites e timeouts
# ============================================================================
SENTINEL_MAX_ITERATIONS=8          # caminho natural usa 5 + 3 de margem p/ 1 retry
SENTINEL_TOKEN_BUDGET=50000
SENTINEL_OBS_TIMEOUT_S=60          # timeout do Observabilidade (Grafana MCP)
SENTINEL_TECNICO_TIMEOUT_S=90      # timeout do Tecnico (filesystem + playwright + github)

# ============================================================================
# Features
# ============================================================================
SENTINEL_GERAR_BACKLOG=1           # apos RCA aprovado, decompoe o fix em backlog. 0 desliga.
